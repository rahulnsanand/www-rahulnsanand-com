{
  "name": "www-rahulnsanand-com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:content": "node scripts/generate-blog-content.mjs && node scripts/generate-robots.mjs && node scripts/generate-llms-txt.mjs && node scripts/generate-sitemap.mjs",
    "predev": "pnpm run sync:content",
    "dev": "next dev",
    "prebuild": "pnpm run sync:content",
    "build": "next build",
    "start": "next start",
    "lint": "node -r ./scripts/eslint-balanced-match-compat.cjs ./node_modules/eslint/bin/eslint.js . && pnpm run lint:theme-cascade",
    "lint:theme-cascade": "node scripts/lint-theme-state-conflicts.mjs",
    "audit:styles": "node scripts/audit-style-ownership.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "validate:css-migration": "pnpm lint && pnpm run audit:styles && pnpm typecheck && pnpm build && pnpm test:visual",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "fuse.js": "^7.1.0",
    "motion": "^12.35.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "balanced-match": "4.0.4"
    }
  }
}
